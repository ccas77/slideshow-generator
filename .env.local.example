# ── Authentication ──────────────────────────────────────
APP_PASSWORD=your-app-password          # Single-user password for the UI
PASSWORD=your-app-password              # Legacy alias used by /api/generate-slides (set same as APP_PASSWORD)
CRON_SECRET=your-cron-secret            # Bearer token for cron jobs and admin routes

# ── Upstash Redis ───────────────────────────────────────
KV_REST_API_URL=https://your-redis.upstash.io   # Upstash Redis REST URL
KV_REST_API_TOKEN=your-upstash-token             # Upstash Redis REST token

# ── External APIs ───────────────────────────────────────
POSTBRIDGE_API_KEY=your-postbridge-key  # PostBridge API key for TikTok/Instagram posting
GEMINI_API_KEY=your-gemini-key          # Google Gemini API key for AI text generation

# ── Optional ────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-key  # Enables AI chat feature
